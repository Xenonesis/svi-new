# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps integration (client-side).
NEXT_PUBLIC_GOOGLE_MAPS_PLATFORM_KEY="YOUR_API_KEY"

# NEXT_PUBLIC_ANALYTICS_ID: Google Analytics tracking ID (e.g., G-XXXXXXXXXX).
# Leave empty to disable analytics.
NEXT_PUBLIC_ANALYTICS_ID=""
