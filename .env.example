# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_ANALYTICS_ID: Google Analytics tracking ID (e.g., G-XXXXXXXXXX).
# Leave empty to disable analytics.
NEXT_PUBLIC_ANALYTICS_ID=""

# ── Supabase ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL: Your project's Supabase URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Safe to expose in the browser (respects RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# SUPABASE_SERVICE_ROLE_KEY: SECRET – never expose to the browser!
# Used server-side only for admin operations (creating users, bypassing RLS).
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# CRON_SECRET: Secret token for Vercel Cron Jobs (cleanup-registrations, lottery, etc.).
# The cron endpoint checks this via Authorization: Bearer <CRON_SECRET> header.
# Generate a random string: openssl rand -hex 32
CRON_SECRET="your-random-cron-secret-here"

# NEXT_PUBLIC_HCAPTCHA_SITE_KEY: Required for Supabase Auth Captcha bot detection (client-side).
# Use '10000000-ffff-ffff-ffff-000000000001' as the standard test key for local development.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000001"

# ── AI Chatbot ────────────────────────────────────────────────────────────────
# GROQ_API_KEY: Required for the AI chatbot. Get a free key at https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# ── Resend (Email) ────────────────────────────────────────────────────────────
# RESEND_API_KEY: Server-side only. Used for transactional emails.
RESEND_API_KEY="re_your_resend_api_key"

# ADMIN_EMAIL: Where contact form and registration notifications are sent.
ADMIN_EMAIL="admin@yourdomain.com"

# ── Resend Inbound Email ───────────────────────────────────────────────────────
# RESEND_INBOUND_DOMAIN: Domain for receiving incoming emails / replies
#   Step 1: Add MX record in your DNS provider:
#     Type: MX, Host: inbound, Value: mx1.resend.com, Priority: 10
#     Type: MX, Host: inbound, Value: mx2.resend.com, Priority: 20
#   Step 2: Configure inbound domain at https://resend.com/domains → Add Domain
#   Step 3: Set webhook URL in Resend dashboard for the inbound domain:
#     https://yourdomain.com/api/webhooks/resend/incoming
#   Step 4: Copy the signing secret from Resend dashboard → Webhooks
# RESEND_INBOUND_DOMAIN="inbound.yourdomain.com"
# RESEND_WEBHOOK_SECRET="whsec_..."

# NEXT_PUBLIC_SHOW_RESEND: Set to 'true' to show Resend usage stats in admin
# NEXT_PUBLIC_SHOW_RESEND=true

